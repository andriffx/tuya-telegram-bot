[Unit]
Description=Telegram Bot Tuya Smart Home
After=network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/telegrambot-tinytuya
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/pi/telegrambot-tinytuya/venv/bin/python bot.py
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
