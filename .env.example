# ============================================================
# TELEGRAM BOT (dari @BotFather)
# ============================================================
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ============================================================
# SMART PLUG - BARDI Smart Plug 16A (COK AIR)
# ============================================================
DEVICE_AIR_ID=your_id
DEVICE_AIR_KEY=your_local_key_here
DEVICE_AIR_IP=your_ip
DEVICE_AIR_VER=device_ver

# ============================================================
# SMART LAMP - BARDI Smart Light Bulb 12W RGBWW
# ============================================================
DEVICE_LAMPU_ID=your_id
DEVICE_LAMPU_KEY=your_local_key_here
DEVICE_LAMPU_IP=your_ip
DEVICE_LAMPU_VER=device_ver

# ============================================================
# ROLE-BASED ACCESS CONTROL (RBAC)
# ============================================================
# Publik  = tanpa akses (bisa /start, /help, /whoami saja)
# User    = + kontrol AIR (on/off)
# Admin   = + kontrol LAMPU (on/off)
# Superadmin = + manajemen user (/users, /allowuser, /removeuser)
#
# Format: id1,id2,id3 (tanpa spasi)
# ============================================================
SUPERADMIN_USERS=
ADMIN_USERS=
USER_USERS=

# ============================================================
# RATE LIMIT — proteksi dari spam & abuse
# Jumlah request maksimal dalam window (detik) per role
# ============================================================
RATE_LIMIT_PUBLIC=10
RATE_LIMIT_USER=30
RATE_LIMIT_ADMIN=60
RATE_LIMIT_SUPERADMIN=120
RATE_LIMIT_WINDOW=60

# ============================================================
# WEB DASHBOARD API (lokal)
# ============================================================
# API key untuk dashboard & REST client (header: X-API-Key)
DASHBOARD_API_KEY=your_secret_api_key_here
API_HOST=0.0.0.0
API_PORT=8080
# Swagger docs — default OFF. Set true hanya untuk development lokal.
API_DOCS=false
